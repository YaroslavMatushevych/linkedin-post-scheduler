# Google Gemini (free tier — aistudio.google.com)
GEMINI_API_KEY=

# Telegram Bot (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # your personal chat_id (get it from @userinfobot)

# LinkedIn (developer.linkedin.com → create app → OAuth)
LINKEDIN_ACCESS_TOKEN=   # long-lived token from scripts/setup_linkedin.py
LINKEDIN_PERSON_URN=     # your LinkedIn member ID (e.g. ACoAA...)

# Upstash Redis (console.upstash.com → free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
