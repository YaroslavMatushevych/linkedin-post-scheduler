# Google Gemini (free — aistudio.google.com)
GEMINI_API_KEY=

# Telegram Bot (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # your personal chat_id (get it from @userinfobot)

# LinkedIn (one-time setup via scripts/setup_linkedin.py)
LINKEDIN_ACCESS_TOKEN=   # expires every ~60 days, re-run setup to refresh
LINKEDIN_PERSON_URN=     # your LinkedIn member ID (printed by setup script)

# GitHub PAT (already set via `gh auth token` — used for Gist state storage)
GH_PAT=
